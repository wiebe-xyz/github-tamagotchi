apiVersion: v1
kind: Secret
metadata:
  name: github-tamagotchi-secrets
  namespace: nijmegen-testing
type: Opaque
stringData:
  database-url: "postgresql+asyncpg://user:password@postgresql:5432/tamagotchi"
  github-token: "ghp_xxxxxxxxxxxxxxxxxxxx"
  openrouter-api-key: "sk-or-v1-xxxxxxxxxxxxxxxxxxxx"
