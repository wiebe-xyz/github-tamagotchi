# Application
APP_NAME=GitHub Tamagotchi
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://tamagotchi:password@localhost:5432/tamagotchi

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_POLL_INTERVAL_MINUTES=30
GITHUB_WEBHOOK_SECRET=

# Image generation
IMAGE_GENERATION_ENABLED=true
IMAGE_GENERATION_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=google/gemini-2.5-flash-image
OPENROUTER_TIMEOUT=60.0

# ComfyUI (optional, set IMAGE_GENERATION_PROVIDER=comfyui to use)
COMFYUI_URL=
COMFYUI_CF_ACCESS_CLIENT_ID=
COMFYUI_CF_ACCESS_CLIENT_SECRET=
COMFYUI_TIMEOUT=120.0

# MinIO/S3 storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tamagotchi
MINIO_SECURE=false

# Server
HOST=0.0.0.0
PORT=8000

# FunnelBarn analytics (client-side, safe to expose)
FUNNELBARN_API_KEY=

# Alerting
ALERTING_ENABLED=false
ALERT_SLACK_WEBHOOK=
ALERT_DISCORD_WEBHOOK=
